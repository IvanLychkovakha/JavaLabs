<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.SeparatorMenuItem?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="563.0" prefWidth="665.0" style="-fx-background-color: #FFFFFF;" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Task1.Controller">
   <children>
      <MenuBar layoutY="2.0" prefHeight="25.0" prefWidth="665.0">
        <menus>
          <Menu mnemonicParsing="false" text="Файл">
            <items>
                  <MenuItem mnemonicParsing="false" onAction="#doNew" text="Новый" />
                  <MenuItem mnemonicParsing="false" onAction="#doOpen" text="Открыть" />
                  <MenuItem mnemonicParsing="false" onAction="#doSave" text="Сохранить" />
                  <SeparatorMenuItem mnemonicParsing="false" />
              <MenuItem mnemonicParsing="false" onAction="#doExit" text="Выйти" />
            </items>
          </Menu>
          <Menu mnemonicParsing="false" text="Редактирование">
            <items>
                  <MenuItem mnemonicParsing="false" onAction="#doAdd" text="Добавить строку" />
              <MenuItem mnemonicParsing="false" onAction="#doRemove" text="Удалить последнюю строку" />
            </items>
          </Menu>
            <Menu mnemonicParsing="false" text="Работа">
              <items>
                  <MenuItem mnemonicParsing="false" onAction="#sortByDate" text="Сортировка по дате" />
                <MenuItem mnemonicParsing="false" onAction="#sortByVisitors" text="Сортировка по количетву поситителей" />
              </items>
            </Menu>
          <Menu mnemonicParsing="false" text="Помощь">
            <items>
              <MenuItem mnemonicParsing="false" onAction="#doAbout" text="Про программу..." />
            </items>
          </Menu>
        </menus>
      </MenuBar>
      <AnchorPane layoutY="27.0" prefHeight="534.0" prefWidth="215.0" style="-fx-background-color: #DCDCDC;">
         <children>
            <TextField fx:id="textFieldName" layoutX="34.0" layoutY="31.0" onAction="#nameChanged" />
            <TextField fx:id="textFieldProfession" layoutX="34.0" layoutY="85.0" onAction="#professionChanged" />
            <Label layoutX="34.0" layoutY="14.0" text="Имя доктора" />
            <Label layoutX="34.0" layoutY="68.0" text="Профессия" />
            <Button layoutX="7.0" layoutY="202.0" mnemonicParsing="false" onAction="#doSearchByWord" prefHeight="25.0" prefWidth="200.0" text="Сумарное кол-во посетителей" />
            <Button layoutX="6.0" layoutY="242.0" mnemonicParsing="false" onAction="#doSearchByMinShift" prefHeight="25.0" prefWidth="200.0" text="Прием с мин кол-вом посетителей" />
            <TextArea fx:id="textAreaResults" layoutX="8.0" layoutY="302.0" prefHeight="200.0" prefWidth="200.0" AnchorPane.bottomAnchor="32.0" AnchorPane.leftAnchor="8.0" AnchorPane.rightAnchor="7.0" AnchorPane.topAnchor="302.0" />
         </children>
      </AnchorPane>
      <TableView fx:id="tableViewAppointment" editable="true" layoutX="215.0" layoutY="27.0" prefHeight="534.0" prefWidth="451.0">
        <columns>
          <TableColumn fx:id="tableColumnDate" prefWidth="132.0" text="Дата" />
          <TableColumn fx:id="tableColumnShift" prefWidth="118.0" text="Смена" />
            <TableColumn fx:id="tableColumnNumOfVisitors" prefWidth="200.0" text="Количество посетителей" />
        </columns>
      </TableView>
   </children>
</AnchorPane>
